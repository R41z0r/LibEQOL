package-as: LibEQOL

enable-nolib-creation: no

ignore:
  - .git
  - .github
  - docs
  - .gitmodules
  - .vscode
  - README-curse.md
  - scripts/*
  - CHANGELOG.md
  - README.md
  - examples/*
  - action.yml

plain-copy:
  - LibEQOLSettingsMode.lua
  - LibEQOLSettingsTemplates.xml

manual-changelog:
  filename: CHANGELOG.md
  markup-type: markdown
